{
  "_meta": {
    "version": "2026-05-21",
    "registry_version": "merchant_registry_v2",
    "description": "External catalog of known subscription merchants and billing intermediaries. Updated as a product asset, not derived from any single user's data. Each merchant carries: canonical display name, category, optional aliases for matching, and known domains.",
    "schema": {
      "merchants": "Array of subscription products (Netflix, Spotify, etc.)",
      "billers": "Array of payment-processor intermediaries that should be unwrapped (Apple, Google Play, PayPal, Stripe, Square)",
      "processor_prefixes": "Leading tokens banks prepend (SQ *, TST*, PAYPAL *, etc.) — stripped before matching"
    }
  },
  "processor_prefixes": [
    "SQ \\*",
    "SQ\\*",
    "TST\\*",
    "TST \\*",
    "PAYPAL \\*",
    "PP\\*",
    "PYP\\*",
    "STRIPE\\*",
    "STR\\*",
    "WP\\*",
    "WPY\\*",
    "GG\\*",
    "GOOGLE \\*",
    "APL\\*",
    "APPLE\\.COM/BILL",
    "EVENTBRITE\\*",
    "GUMROAD\\*",
    "TOAST\\*",
    "VENMO\\*",
    "CASHAPP\\*",
    "CKE\\*",
    "ACI\\*",
    "MSP\\*",
    "MS\\*",
    "AMZN MKTP",
    "AMAZON\\.COM\\*"
  ],
  "trailing_noise": [
    "\\s+\\d{3,}$",
    "\\s+#\\d+$",
    "\\s+\\*\\d+$",
    "\\s+[A-Z]{2}\\s*$",
    "\\s+\\d{3}-\\d{3}-\\d{4}.*$",
    "\\s+\\(\\d{3}\\)\\s*\\d{3}-\\d{4}.*$",
    "\\s+STORE\\s+\\d+.*$",
    "\\s+LOCATION\\s+\\d+.*$",
    "\\s+ID:[A-Z0-9]+.*$",
    "\\s+REF:[A-Z0-9]+.*$",
    "\\s+TXN:[A-Z0-9]+.*$"
  ],
  "billers": [
    {
      "key": "apple",
      "display": "Apple",
      "aliases": ["apple.com/bill", "apple.com bill", "apl* itunes", "apple itunes", "itunes.com/bill", "itunes", "app store"],
      "domains": ["apple.com", "itunes.com"],
      "note": "Apple bills many subscriptions through one descriptor. Real product is often discoverable in the long-form descriptor or the amount pattern."
    },
    {
      "key": "google_play",
      "display": "Google Play",
      "aliases": ["google *", "google play", "gg* google", "google.com play", "google payments"],
      "domains": ["play.google.com", "google.com"],
      "note": "Same multi-product biller pattern as Apple."
    },
    {
      "key": "paypal",
      "display": "PayPal",
      "aliases": ["paypal *", "pp*", "pyp*", "paypal inst", "paypal verified"],
      "domains": ["paypal.com"],
      "note": "PayPal wraps many merchants. The actual merchant name follows the asterisk in most cases."
    },
    {
      "key": "stripe",
      "display": "Stripe",
      "aliases": ["stripe*", "str*", "stripe.com"],
      "domains": ["stripe.com"],
      "note": "Stripe descriptors usually expose the actual merchant after the asterisk."
    },
    {
      "key": "square",
      "display": "Square",
      "aliases": ["sq *", "sq*", "square*", "squareup"],
      "domains": ["squareup.com", "square.com"]
    }
  ],
