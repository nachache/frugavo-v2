# Frugavo environment variables.
#
# Copy this file to .env.local for local dev, or paste the values
# into Netlify → Site settings → Environment variables for prod.
#
# Conventions:
#   - NEXT_PUBLIC_* values are shipped to the browser — anything
#     here is effectively public.
#   - Everything else is server-only.
#
# Required vs optional is noted on each block.

# =========================================================================
# REQUIRED — without these the app won't boot in any meaningful way.
# =========================================================================

# -------------------------------------------------------------------------
# Supabase — primary database.
# Supabase dashboard → Project Settings → API.
# -------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxx

# -------------------------------------------------------------------------
# Clerk — authentication.
# clerk.com → application → API Keys.
# Publishable is browser-safe; secret MUST stay server-side.
# In prod, swap the test keys for live keys (pk_live_..., sk_live_...).
# -------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_SECRET_KEY=sk_test_xxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/app
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/app

# -------------------------------------------------------------------------
# Plaid — bank connection.
# dashboard.plaid.com → Team Settings → Keys.
# PLAID_ENV: sandbox | development | production.
# Production requires the signed Plaid MSA + approved application.
# -------------------------------------------------------------------------
PLAID_CLIENT_ID=xxxxx
PLAID_SECRET=xxxxx
PLAID_ENV=sandbox

# -------------------------------------------------------------------------
# Stripe — payments.
# dashboard.stripe.com → Developers → API keys.
# Live mode (prod) needs new Product + Price IDs — test-mode IDs
# don't resolve in live. Re-run scripts/configure-portal.ts against
# live keys before launch.
# -------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_PRODUCT_PEACE_OF_MIND=prod_xxxxx
STRIPE_PRICE_PEACE_OF_MIND_MONTHLY_V1=price_xxxxx

# -------------------------------------------------------------------------
# Resend — transactional email (billing, alerts, signup notice).
# resend.com → API Keys.
# Domain must be verified + SPF/DKIM/DMARC records added in DNS
# before anything will land in inboxes (vs. spam).
# -------------------------------------------------------------------------
RESEND_API_KEY=re_xxxxx
RESEND_FROM_EMAIL="Frugavo <hello@frugavo.com>"

# -------------------------------------------------------------------------
# Anthropic — Claude classifier (engine + merchant resolver).
# console.anthropic.com → API Keys.
# -------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxxxx

# -------------------------------------------------------------------------
# Upstash Redis — verdict cache + rate limiting.
# console.upstash.com → Redis → REST API.
# -------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxx

# -------------------------------------------------------------------------
# App URL — canonical origin used by webhooks, OG images, share links,
# email templates. Must include scheme. No trailing slash.
# Local dev: http://localhost:3000
# Prod:      https://frugavo.com
# -------------------------------------------------------------------------
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -------------------------------------------------------------------------
# Cron / scheduled function shared secret.
# Generate with: openssl rand -hex 32
# Netlify scheduled functions and external triggers must pass this
# in the Authorization header.
# -------------------------------------------------------------------------
CRON_SECRET=replace-with-random-32-byte-hex

# -------------------------------------------------------------------------
# One-click unsubscribe link signing secret.
# Generate with: openssl rand -hex 32
# Signs the HMAC in unsubscribe URLs so they can't be forged.
# -------------------------------------------------------------------------
UNSUBSCRIBE_HMAC_SECRET=replace-with-random-32-byte-hex

# -------------------------------------------------------------------------
# Plaid access-token encryption-at-rest key.
# Generate with: openssl rand -base64 32
# 32-byte AES-256 key, base64 encoded. Loss = inability to decrypt
# stored Plaid access_tokens — rotation requires re-prompting every
# user to re-link.
# -------------------------------------------------------------------------
TOKEN_ENCRYPTION_KEY=replace-with-base64-32-byte-key

# =========================================================================
# OPTIONAL — features degrade gracefully when these are absent.
# =========================================================================

# -------------------------------------------------------------------------
# Sentry — error tracking. App boots without it.
# sentry.io → Project Settings → Client Keys (DSN).
# -------------------------------------------------------------------------
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# -------------------------------------------------------------------------
# Google Analytics 4. Tag only renders when set.
# analytics.google.com → Admin → Data Streams → Measurement ID.
# -------------------------------------------------------------------------
NEXT_PUBLIC_GA_ID=

# -------------------------------------------------------------------------
# Stripe customer-portal display URLs. Drop these and the portal
# uses Stripe's defaults.
# -------------------------------------------------------------------------
STRIPE_PORTAL_BUSINESS_PROFILE_PRIVACY_URL=https://frugavo.com/privacy
STRIPE_PORTAL_BUSINESS_PROFILE_TOS_URL=https://frugavo.com/terms

# -------------------------------------------------------------------------
# Admin / dev helpers. NEVER set in prod unless intentional.
# -------------------------------------------------------------------------
# Comma-separated list of Clerk user IDs allowed to hit /app/admin.
FRUGAVO_ADMIN_USER_IDS=
# When "true", exposes /api/dev/full-reset-and-load. Keep unset in prod.
FRUGAVO_DEV_RESET_ALLOWED=
# Default user ID for scripts/verify-scan-live.ts and friends.
FRUGAVO_VERIFY_USER_ID=
FRUGAVO_SCAN_DEBUG_USER_ID=
FRUGAVO_SANDBOX_DEMO_USER_ID=

# -------------------------------------------------------------------------
# Legacy / deprecated alias for RESEND_FROM_EMAIL. Some older code
# paths still read it. Safe to leave unset once those are migrated.
# -------------------------------------------------------------------------
FROM_EMAIL=

# -------------------------------------------------------------------------
# Variants of CRON_SECRET. Older code expects FRUGAVO_CRON_SECRET on
# the retrain-scoring-model endpoint. Set to the same value as
# CRON_SECRET, or migrate that route to CRON_SECRET (see L13).
# -------------------------------------------------------------------------
FRUGAVO_CRON_SECRET=

# -------------------------------------------------------------------------
# Netlify-provided. Don't set manually; Netlify injects them.
# URL / DEPLOY_URL / DEPLOY_PRIME_URL / CONTEXT etc.
# -------------------------------------------------------------------------
