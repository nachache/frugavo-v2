# Copy this file to .env.local and fill in real values.

# -------------------------------------------------------------------------
# Supabase
# Get from the Supabase dashboard → Project Settings → API.
# -------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxx

# -------------------------------------------------------------------------
# Clerk — authentication
# Get from clerk.com → your application → API Keys.
# The publishable key is safe to ship to the browser; the secret key MUST
# stay server-side only.
# -------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_SECRET_KEY=sk_test_xxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/app
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/app

# -------------------------------------------------------------------------
# Plaid — bank connection
# Get from dashboard.plaid.com → Team Settings → Keys.
# Start in `sandbox` for dev, `development` for limited real banks,
# `production` once the Plaid MSA is signed.
# -------------------------------------------------------------------------
PLAID_CLIENT_ID=xxxxx
PLAID_SECRET=xxxxx
PLAID_ENV=sandbox

# -------------------------------------------------------------------------
# Stripe — payments (added in week 4)
# Get from dashboard.stripe.com → Developers → API keys.
# -------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx

# -------------------------------------------------------------------------
# Google Analytics 4
# Get from analytics.google.com → Admin → Data Streams → Measurement ID.
# The GA tag only renders when this var is set; leave empty in dev to
# disable analytics locally.
# -------------------------------------------------------------------------
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
