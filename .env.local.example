# Copy this file to .env.local and fill in real values.

# Supabase — get from the Supabase dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Google Analytics 4 — get from analytics.google.com →
# Admin → Property → Data Streams → your stream → Measurement ID.
# The GA tag only renders when this var is set; leave empty in dev to
# disable analytics locally.
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
